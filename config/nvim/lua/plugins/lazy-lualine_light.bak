local dracula_colors = {
	drx_color_base = '#FFFBEB',
	drx_color_overlay = '#DEDBCC',
	drx_color_highlight = '#CECCC0',
	drx_color_text = '#1F1F1F',
	drx_color_accent = '#CB3A2A',
	drx_color_orange = '#036A96',
	drx_color_red = '#CB3A2A',
	drx_color_yellow = '#846E15',
	drx_color_green = '#14710A',
}

local function generate_theme(colors)
	return {
		normal = {
			a = { bg = colors.drx_color_accent, fg = colors.drx_color_base, gui = 'bold' },
			b = { bg = colors.drx_color_highlight, fg = colors.drx_color_text },
			c = { bg = colors.drx_color_overlay, fg = colors.drx_color_text },
		},
		insert = {
			a = { bg = colors.drx_color_green, fg = colors.drx_color_base, gui = 'bold' },
			b = { bg = colors.drx_color_highlight, fg = colors.drx_color_text },
			c = { bg = colors.drx_color_overlay, fg = colors.drx_color_text },
		},
		visual = {
			a = { bg = colors.drx_color_yellow, fg = colors.drx_color_base, gui = 'bold' },
			b = { bg = colors.drx_color_highlight, fg = colors.drx_color_text },
			c = { bg = colors.drx_color_overlay, fg = colors.drx_color_text },
		},
		replace = {
			a = { bg = colors.drx_color_red, fg = colors.drx_color_base, gui = 'bold' },
			b = { bg = colors.drx_color_highlight, fg = colors.drx_color_text },
			c = { bg = colors.drx_color_overlay, fg = colors.drx_color_text },
		},
		command = {
			a = { bg = colors.drx_color_orange, fg = colors.drx_color_base, gui = 'bold' },
			b = { bg = colors.drx_color_highlight, fg = colors.drx_color_text },
			c = { bg = colors.drx_color_overlay, fg = colors.drx_color_text },
		},
		inactive = {
			a = { bg = colors.drx_color_overlay, fg = colors.drx_color_text, gui = 'bold' },
			b = { bg = colors.drx_color_highlight, fg = colors.drx_color_text },
			c = { bg = colors.drx_color_overlay, fg = colors.drx_color_text },
		},
	}
end

return {
	"nvim-lualine/lualine.nvim",
	event = "VeryLazy",
	opts = {
		options = {
			icons_enabled = true,
			theme = generate_theme(dracula_colors),
			component_separators = "",
			section_separators = {
				left = "",
				right = ""
			},
			disabled_filetypes = {
				statusline = {"dashboard"},
				winbar = {}
			},
			ignore_focus = {},
			always_divide_middle = true,
			globalstatus = false,
			refresh = {
				statusline = 100,
				tabline = 1000,
				winbar = 1000
			}
		},
		sections = {
			lualine_a = {{
				function()
					local recording_register = vim.fn.reg_recording()
					if recording_register == '' then
						return ({
							n = "NORMAL",
							no = "NORMAL",
							v = "VISUAL",
							V = "V-LINE",
							[""] = "V-BLOCK",
							i = "INSERT",
							ic = "INSERT",
							R = "REPLACE",
							Rv = "V-REPLACE",
							c = "COMMAND",
							cv = "EX",
							ce = "EX",
							r = "PROMPT",
							rm = "MORE",
							["r?"] = "CONFIRM",
							["!"] = "SHELL",
							t = "TERMINAL",
						})[vim.fn.mode()] or "UNKNOWN"
					else
						return 'RECORDING @' .. recording_register
					end
				end,
				color = function()
					if vim.fn.reg_recording() ~= '' then
						return { bg = dracula_colors.drx_color_red, fg = dracula_colors.drx_color_base, gui = 'bold' }
					else
						return {gui = 'bold'}
					end
				end,
				separator = {
					left = "",
					right = ""
				},
				icon = '',
				right_padding = 2
			}},
			lualine_b = {{
				"filename",
				icon = ' '
			}},
			lualine_c = {"branch", "diff", "diagnostics"},
			lualine_x = {"selectioncount", "searchcount"},
			lualine_y = {{
				"filesize",
				icon = '󰖡 ',
			}},
			lualine_z = {{
				"location",
				separator = {
					left = "",
					right = ""
				},
				left_padding = 2,
				icon = ''
			}}
		},
		inactive_sections = {
			lualine_a = {{
				"mode",
				separator = {
					left = "",
					right = ""
				},
				right_padding = 2
			}},
			lualine_b = {"branch", "diff", "diagnostics"},
			lualine_c = {"%=", "filename"},
			lualine_x = {},
			lualine_y = {"filetype", "filesize"},
			lualine_z = {{
				"location",
				separator = {
					left = "",
					right = ""
				},
				left_padding = 2
			}}
		},
		winbar = {},
		inactive_winbar = {},
		extensions = {}
	}
}
