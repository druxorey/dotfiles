#!/bin/bash

declare FORMAT_SUCCESS="\e[1;32m[SUCCESS]"
declare FORMAT_ERROR="\e[1;31m[ERROR]"
declare FORMAT_TITLE="\e[1;34m"
declare FORMAT_RESET="\e[0m"

function help() {
	echo -e "${FORMAT_TITLE}USAGE:${FORMAT_RESET} $(basename "$0") [OPTIONS] INPUT_FILE

${FORMAT_TITLE}DESCRIPTION:${FORMAT_RESET}
    Compresses a video file using ffmpeg with a specified compression level.

${FORMAT_TITLE}ARGUMENTS:${FORMAT_RESET}
    INPUT_FILE             The video file to be compressed.

${FORMAT_TITLE}OPTIONS:${FORMAT_RESET}
    -o OUTPUT_FILE         Specify the name of the output file. (Optional)
    -l COMPRESSION_LEVEL   Compression level (0-3). (Optional)
                           0: Low compression (default)
                           1: Medium compression
                           2: High compression
                           3: Maximum compression

${FORMAT_TITLE}EXAMPLES:${FORMAT_RESET}
    $(basename "$0") -o output.mkv -l 2 input.mp4
    $(basename "$0") input.mp4"
	exit 0
}


function main() {
	local outputFile=""
	local compressionLevel=0

	while getopts "o:l:h" opt; do
		case $opt in
			o) outputFile="$OPTARG" ;;
			l) compressionLevel="$OPTARG" ;;
			h) help ;;
			*) exit 1 ;;
		esac
	done

	shift $((OPTIND - 1))
	local inputFile="$1"

	if [[ -z "$inputFile" ]]; then
		printf "%b Input file is required%b\n" "${FORMAT_ERROR}" "${FORMAT_RESET}"
		exit 1
	fi

    local inputDir
    local baseName
    local extension
    inputDir=$(dirname "$inputFile")
    baseName=$(basename "$inputFile")
    extension="${baseName##*.}"
    baseName="${baseName%.*}"

	if [[ -z "$outputFile" ]]; then
		outputFile="${inputDir}/${baseName}_${compressionLevel}.${extension}"
		
		local counter=1
		while [[ -f "$outputFile" ]]; do
			outputFile="${inputDir}/${baseName}_${compressionLevel}(${counter}).${extension}"
			((counter++))
		done
	fi

	local vcodec="libx265"
	local preset="slow"
	local crf=28
	local acodec="aac"
	local audioBitrate="128k"

	case $compressionLevel in
		0) crf=17; acodec="copy" ;;
		1) crf=23; acodec="aac"; audioBitrate="192k";;
		2) crf=28; acodec="aac"; audioBitrate="128k";;
		3) crf=33; preset="slower"; acodec="aac"; audioBitrate="96k";;
		*)
			printf "%b Compression level '%s' is invalid. Valid options are: [0, 1, 2, 3]%b\n" "${FORMAT_ERROR}" "$compressionLevel" "${FORMAT_RESET}"
			exit 1
			;;
	esac

	local ffmpegCMD=(ffmpeg -hide_banner -y -i "$inputFile")
	ffmpegCMD+=(-map 0)
	ffmpegCMD+=(-c:v "$vcodec" -preset "$preset" -crf "$crf")
	ffmpegCMD+=(-c:a "$acodec")
	if [[ "$acodec" != "copy" ]]; then
		ffmpegCMD+=(-b:a "$audioBitrate")
	fi
	ffmpegCMD+=(-c:s copy -map_metadata 0)
	if [[ "${extension,,}" == "mp4" ]]; then
		ffmpegCMD+=(-movflags +faststart)
	fi

	ffmpegCMD+=("$outputFile")

	"${ffmpegCMD[@]}" || {
		printf "%b Failed to compress the file '%s'%b\n" "${FORMAT_ERROR}" "$inputFile" "${FORMAT_RESET}"
		exit 1
	}

	printf "\n%b File '%s' compressed to '%s' with compression level %s%b\n" "${FORMAT_SUCCESS}" "$inputFile" "$outputFile" "$compressionLevel" "${FORMAT_RESET}"

	return 0
}

main "$@"
