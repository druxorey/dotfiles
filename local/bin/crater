#!/bin/bash

declare FORMAT_SUCCESS="\e[1;32m[SUCCESS]\e[0m"
declare FORMAT_ERROR="\e[1;31m[ERROR]\e[0m"

declare TEMPLATES_PATH="$HOME/.local/share/crater"
declare EXTENSION=""
declare -a FILES=()

function help() {
	local FORMAT_BOLD="\e[1;34m"
	local FORMAT_RESET="\e[0m"
	echo -e "${FORMAT_BOLD}USAGE:${FORMAT_RESET} $(basename "$0") [OPTIONS] FILE_TYPE

${FORMAT_BOLD}DESCRIPTION:${FORMAT_RESET}
    Creates a default file in a specific programming language.

${FORMAT_BOLD}ARGUMENTS:${FORMAT_RESET}
    FILE_TYPE              bash, c, c++, go, html, java, latex, lua, python, rust.

${FORMAT_BOLD}OPTIONS:${FORMAT_RESET}
    -n FILE_NAME           The name of the file to create (default: default).
    -i INDEX               The index of the template to use (skips manual selection).

${FORMAT_BOLD}EXAMPLES:${FORMAT_RESET}
    $(basename "$0") html
    $(basename "$0") -n code -i 2 python"

	return 0
}


function copyFromTemplate() {
	local index=$1

	if [[ -z "${FILES[$index]}" ]] || ! [[ "$index" =~ ^[0-9]+$ ]]; then
		printf "%b Invalid index: '%s'\n" "$FORMAT_ERROR" "$index" >&2
		exit 1
	fi

	local templatePath="${FILES[$index]}"
	[[ -d "$templatePath" ]] && filePath="${2}" || filePath="${2}.${EXTENSION}"

	cp -rp "$templatePath" "$filePath" || {
		printf "%b Failed to create file '%s'.\n" "$FORMAT_ERROR" "$filePath" >&2
		exit 1
	}

	printf "%b File '%s' created.\n" "$FORMAT_SUCCESS" "$filePath"

	return 0
}


function main() {
	local fileName="default"
	local templateIndex=""

	while getopts "n:i:h" opt; do
		case $opt in
			n) fileName="$OPTARG" ;;
			i) templateIndex="$OPTARG" ;;
			h) help && exit 0 ;;
			*) printf "%b Try '%s -h' for more information.\n" "$FORMAT_ERROR" "$(basename "$0")" >&2 && exit 1 ;;
		esac
	done

	shift $((OPTIND - 1))

	local fileType=$1

	[[ -z "$fileType" ]] && printf "%b File type is required.\n" "$FORMAT_ERROR" >&2 && exit 1
	[[ ! -d "$TEMPLATES_PATH" ]] && printf "%b Templates directory '%s' not found.\n" "$FORMAT_ERROR" "$TEMPLATES_PATH" >&2 && exit 1;

	case $fileType in
		"bash")   EXTENSION="sh"   ;;
		"c")      EXTENSION="c"    ;;
		"c++")    EXTENSION="cpp"  ;;
		"cpp")    EXTENSION="cpp"  ;;
		"golang") EXTENSION="go"   ;;
		"go")     EXTENSION="go"   ;;
		"html")   EXTENSION="html" ;;
		"java")   EXTENSION="java" ;;
		"latex")  EXTENSION="tex"  ;;
		"lua")    EXTENSION="lua"  ;;
		"python") EXTENSION="py"   ;;
		"rust")   EXTENSION="rs"   ;;
		"sh")     EXTENSION="sh"   ;;
		"shell")  EXTENSION="sh"   ;;
		"tex")    EXTENSION="tex"  ;;
		*) printf "%b File type '%s' not found.\n" "$FORMAT_ERROR" "$fileType" >&2 && exit 1 ;;
	esac

	for file in "$TEMPLATES_PATH/$EXTENSION"/*; do
		[[ -e "$file" ]] && FILES+=("$file")
	done

	if [[ -n "$templateIndex" ]]; then
		copyFromTemplate "$templateIndex" "$fileName"
		exit 0
	fi

	printf "Available templates with extension '%s':\n" "$EXTENSION"
	for index in "${!FILES[@]}"; do
		if [[ -d ${FILES[$index]} ]]; then
			printf "  [%d] \e[1;34m%s/\e[0m\n" "$index" "$(basename "${FILES[$index]}")"
		else
			printf "  [%d] %s\n" "$index" "$(basename "${FILES[$index]}")"
		fi
	done

	printf "Enter the file index [0-9]: "
	read -r ans

	copyFromTemplate "$ans" "$fileName"

	exit 0
}

main "$@"
