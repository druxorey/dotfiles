#!/bin/bash

declare -r FORMAT_SUCCESS="\e[1;32m[SUCCESS]\e[0m"
declare -r FORMAT_ERROR="\e[1;31m[ERROR]\e[0m"

function connect() {
	printf "Select resolution:\n"
	printf "1) 1330x768\n"
	printf "2) 1600x900\n"
	printf "3) 1920x1080\n"
	printf "Enter your choice [1-3]: "
	read -r ans

	local resolution=""
	case $ans in
		1) resolution="1330x768" ;;
		2) resolution="1600x900" ;;
		3) resolution="1920x1080" ;;
		*) printf "%b Invalid choice: '%s'.\n" "$FORMAT_ERROR" "$ans" >&2 && exit 1 ;;
	esac

	printf "Setting HDMI resolution to %s.\n" "$resolution"

	xrandr --output eDP-1 --auto --primary  --output HDMI-1 --mode $resolution --right-of eDP-1

	if [[ $? -ne 0 ]]; then
		printf "%b Failed to connect HDMI.\n" "$FORMAT_ERROR" >&2
		return 1
	fi

	return 0
}


function disconnect() {
	xrandr --output HDMI-1 --off

	if [[ $? -ne 0 ]]; then
		printf "%b Failed to disconnect HDMI.\n" "$FORMAT_ERROR" >&2
		return 1
	fi
	printf "%b HDMI disconnected successfully.\n" "$FORMAT_SUCCESS"

	return 0
}


function main() {
	while getopts "h" opt; do
		case $opt in
			h) printf "\e[1;34mUSAGE:\e[0m %s {connect|disconnect}\n" "$(basename "$0")" && exit 0 ;;
			*) printf "%b Try '%s -h' for more information.\n" "$FORMAT_ERROR" "$(basename "$0")" >&2 && exit 1 ;;
		esac
	done

	local option="$1"
	[[ -z "$option" ]] && printf "%b No option provided. Try '%s -h' for more information.\n" "$FORMAT_ERROR" "$(basename "$0")" >&2 && exit 1

	if [[ $option == "connect" ]]; then
		connect
	elif [[ $option == "disconnect" ]]; then
		disconnect
	else
		printf "%b Invalid option: '%s'. Try '%s -h' for more information.\n" "$FORMAT_ERROR" "$option" "$(basename "$0")" >&2 && exit 1
	fi

	bspc wm -r

	return 0
}

main "$@"
