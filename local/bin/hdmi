#!/bin/bash

declare FORMAT_TITLE="\e[1;34m"
declare FORMAT_WARNING="\e[1;33m[WARNING]"
declare FORMAT_RESET="\e[0m"

function help() {
	printf "%bUSAGE:%b $(basename "$0") {connect|disconnect}\n" "$FORMAT_TITLE" "$FORMAT_RESET"
	exit 1
}


function connect() {
	printf "Select resolution:\n"
	printf "1) 1330x768\n"
	printf "2) 1600x900\n"
	printf "3) 1920x1080\n"
	printf "Enter your choice [1-3]: "
	read -r ans

	local resolution="1330x768"
	case $ans in
		1) resolution="1330x768" ;;
		2) resolution="1600x900" ;;
		3) resolution="1920x1080" ;;
		*) printf "%b Invalid choice: '%s'%b\n" "$FORMAT_WARNING" "$ans" "$FORMAT_RESET";;
	esac

	printf "Setting HDMI resolution to %s %b\n" "$resolution" "$FORMAT_RESET"

	xrandr --output eDP-1 --primary --mode 1920x1080 --rotate normal --output HDMI-1 --mode $resolution --rate 60 --rotate normal --right-of eDP-1
	bspc wm -r
}


function disconnect() {
	xrandr --output HDMI-1 --off
	bspc wm -r
}


function main() {
	if [[ $# -eq 0 ]]; then
		help
	fi

	option=$1

	if [[ $option == "connect" ]]; then
		connect
	elif [[ $option == "disconnect" ]]; then
		disconnect
	else
		help
	fi
}

main "$@"
