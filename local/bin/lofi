#!/bin/bash

declare FORMAT_TITLE="\e[1;34m"
declare FORMAT_RESET="\e[0m"

declare COVER_PATH="$HOME/.local/share/lofi"

function help() {
	printf "%bUSAGE:%b $(basename "$0") VOLUME\n" "$FORMAT_TITLE" "$FORMAT_RESET"
	exit 1
}


function main() {
	[[ $1 == "-h" ]] && help

	local volume="0.5"
	if [[ -n $1 ]]; then
		volume=$(echo "scale=2; $1 / 100" | bc)
	fi

	if [[ ! -d "$COVER_PATH" ]]; then
		mkdir "$COVER_PATH"
		wget --output-document "$COVER_PATH/lofi.jpg" "https://f4.bcbits.com/img/a0591684555_10.jpg"
	fi

	(
		yt-dlp --format "w*" -o - 'https://www.youtube.com/watch?v=jfKfPfyJRdk' | ffplay -nodisp -af "volume=$volume" -
	) > /dev/null 2>&1 &

	cp -f "$HOME/.local/share/lofi/lofi.jpg" "/tmp/thumbnail.jpg"
    PGID=$(ps -o pgid= -p $! | tr -d ' ')
	cava
    kill -TERM -$PGID:
}

main "$@"
