#!/bin/bash

declare FORMAT_SUCCESS="\e[1;32m[SUCCESS]"
declare FORMAT_ERROR="\e[1;31m[ERROR]"
declare FORMAT_RESET="\e[0m"

declare VAULT_PATH="${HOME}/Documents/A1 Obsidian/"

function main() {
	if [ ! -d "${VAULT_PATH}/.git" ]; then
		printf "%b Obsidian vault not found%b\n" "$FORMAT_ERROR" "$FORMAT_RESET"
		exit 1
	fi

	(
		cd "${VAULT_PATH}" || { printf "%b Failed to change directory%b\n" "$FORMAT_ERROR" "$FORMAT_RESET"; return; }
		git checkout --orphan temp_branch || { printf "%b Failed to create orphan branch%b\n" "$FORMAT_ERROR" "$FORMAT_RESET"; return; }
		git add -A && git commit -m "Clean branch - $(date +%d-%m-%Y_%H-%M-%S)" || { printf "%b Failed to commit changes%b\n" "$FORMAT_ERROR" "$FORMAT_RESET"; return; }
		git branch -D main || { printf "%b Failed to delete main branch%b\n" "$FORMAT_ERROR" "$FORMAT_RESET"; return; }
		git branch -m main || { printf "%b Failed to rename branch to main%b\n" "$FORMAT_ERROR" "$FORMAT_RESET"; return; }
		git push -f origin main || { printf "%b Failed to push to origin%b\n" "$FORMAT_ERROR" "$FORMAT_RESET"; return; }
	)

	printf "%b Obsidian vault cleaned%b\n" "$FORMAT_SUCCESS" "$FORMAT_RESET"
}

main "$@"
