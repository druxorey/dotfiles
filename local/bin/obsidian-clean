#!/bin/bash

declare -r FORMAT_SUCCESS="\e[1;32m[SUCCESS]\e[0m"
declare -r FORMAT_ERROR="\e[1;31m[ERROR]\e[0m"

declare -r VAULT_PATH="${HOME}/Documents/A1 Obsidian/"

function main() {
	if [ ! -d "${VAULT_PATH}/.git" ]; then
		printf "%b Obsidian vault not found.\n" "$FORMAT_ERROR"
		exit 1
	fi

	(
		cd "${VAULT_PATH}" || { printf "%b Failed to change directory.\n" "$FORMAT_ERROR"; exit 0; }
		git checkout --orphan temp_branch || { printf "%b Failed to create orphan branch.\n" "$FORMAT_ERROR"; exit 0; }
		git add -A
		git commit -m "Clean branch - $(date +%d-%m-%Y_%H-%M-%S)" || { printf "%b Failed to commit changes.\n" "$FORMAT_ERROR"; exit 0; }
		git branch -D main || { printf "%b Failed to delete main branch.\n" "$FORMAT_ERROR"; exit 0; }
		git branch -m main || { printf "%b Failed to rename branch to main.\n" "$FORMAT_ERROR"; exit 0; }
		git push -f origin main || { printf "%b Failed to push to origin.\n" "$FORMAT_ERROR"; exit 0; }
	)

	printf "%b Obsidian vault cleaned.\n" "$FORMAT_SUCCESS"

	return 0
}

main "$@"
