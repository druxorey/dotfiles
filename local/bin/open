#!/bin/bash

declare FORMAT_ERROR="\e[1;31m[ERROR]"
declare FORMAT_TITLE="\e[1;34m"
declare FORMAT_RESET="\e[0m"

function help() {
	printf "%bUSAGE:%b $(basename "$0") INPUT_FILE\n" "$FORMAT_TITLE" "$FORMAT_RESET"
	exit 1
}


function main() {
	local file="$1"

	while getopts "h" opt; do
		case $opt in
			h) help ;;
			*) exit 1 ;;
		esac
	done

	[ -z "$file" ] && help

	case $file in
		*.mp4)  mpv     "$file" ;;
		*.mkv)  mpv     "$file" ;;
		*.mp3)  mpv     "$file" ;;
		*.avi)  mpv     "$file" ;;
		*.flac) mpv     "$file" ;;
		*.png)  nsxiv   "$file" ;;
		*.webp) nsxiv   "$file" ;;
		*.jpeg) nsxiv   "$file" ;;
		*.jpg)  nsxiv   "$file" ;;
		*.svg)  nsxiv   "$file" ;;
		*.pdf)  zathura "$file" ;;
		*) printf "%b '$file' cannot be open via open() %b\n" "$FORMAT_ERROR" "$FORMAT_RESET" ;;
	esac
}

main "$@"
