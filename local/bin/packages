#!/usr/bin/env python3

import os
import sys
import subprocess
import urllib.request
import json
from typing import Dict, List, Optional

FORMAT_ERROR = "\033[1;31m[ERROR]"
FORMAT_SUCCESS = "\033[1;32m[SUCCESS]"
FORMAT_TITLE = "\033[0;34m"
FORMAT_RESET = "\033[0m"

PACKAGES_FILES_PATH = "/home/druxorey/Workspace/Projects/dotfiles/"
PACKAGES_FILES_PATH = os.path.expanduser(PACKAGES_FILES_PATH)
PACKAGES_FILES = {"base": "drx-base.packages", "extra": "drx-extra.packages"}

def printHelp():
    print(f"""{FORMAT_TITLE}USAGE:{FORMAT_RESET}
    packages <command> [<arguments>]

{FORMAT_TITLE}COMMANDS:{FORMAT_RESET}
    add <package>           Adds a package. The script will check if it exists in Pacman or
                            the AUR and ask you which list (base/extra) to add it to.

    remove <package>        Searches for the package across all lists and removes it.

    search <package>        Checks if you already have a package registered in your lists 
                            and tells you exactly where it is located.

    list [filter]           Shows all the saved packages.
                            Optional filters: 'base', 'extra', 'pacman', 'aur'.

{FORMAT_TITLE}EXAMPLES:{FORMAT_RESET}
    packages add neovim
    packages remove firefox
    packages search htop
    packages list aur""")


def isInPacman(pkgName: str) -> bool:
    try:
        # -Si looks for exact package info. If the exit code is 0, it exists.
        result = subprocess.run(['pacman', '-Si', pkgName], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return result.returncode == 0
    except FileNotFoundError:
        return False


def isInAur(pkgName: str) -> bool:
    url = f"https://aur.archlinux.org/rpc/?v=5&type=info&arg={pkgName}"
    try:
        req = urllib.request.Request(url)
        with urllib.request.urlopen(req) as response:
            data = json.loads(response.read().decode())
            return data.get("resultcount", 0) > 0
    except Exception:
        return False


def loadPackages(listType: str) -> Dict[str, List[str]]:
    filePath = os.path.join(PACKAGES_FILES_PATH, PACKAGES_FILES[listType])
    packages: Dict[str, List[str]] = {"pacman": [], "aur": []}

    if not os.path.exists(filePath):
        return packages

    with open(filePath, "r") as file:
        currentList: Optional[str] = None
        for line in file:
            line = line.strip()
            # Identify which block we are reading
            if line.startswith(f"{listType}_pacman_packages=("):
                currentList = "pacman"
            elif line.startswith(f"{listType}_aur_packages=("):
                currentList = "aur"
            elif line == ")":
                currentList = None
            elif currentList and line and not line.startswith("#"):
                packages[currentList].append(line)

    return packages


def loadAllPackages() -> Dict[str, Dict[str, List[str]]]:
    return {"base": loadPackages("base"), "extra": loadPackages("extra")}


def savePackages(listType: str, packages: Dict[str, List[str]]) -> None:
    filePath = os.path.join(PACKAGES_FILES_PATH, PACKAGES_FILES[listType])

    os.makedirs(os.path.dirname(filePath), exist_ok=True)

    with open(filePath, "w") as file:
        file.write("#!/bin/bash\n\n")
        for repoType in ["pacman", "aur"]:
            file.write(f"{listType}_{repoType}_packages=(\n")
            # Sort alphabetically and remove duplicates (using set)
            sortedPackages = sorted(set(packages[repoType]))
            for pkg in sortedPackages:
                file.write(f"\t{pkg}\n")
            file.write(")\n\n")


def findPackageLocation(pkgName: str, allPackages: Dict[str, Dict[str, List[str]]]) -> Optional[tuple[str, str]]:
    for listCategory in ["base", "extra"]:
        for packageCategory in ["pacman", "aur"]:
            if pkgName in allPackages[listCategory][packageCategory]:
                return listCategory, packageCategory
    return None


def addPackage(pkgName: str) -> None:
    repoType: str = ""
    if isInPacman(pkgName):
        repoType = "pacman"
    elif isInAur(pkgName):
        repoType = "aur"
    else:
        print(f"{FORMAT_ERROR} Package '{pkgName}' was not found in Pacman or the AUR.{FORMAT_RESET}")
        return

    allPackages: Dict[str, Dict[str, List[str]]] = loadAllPackages()
    location: Optional[tuple[str,str]] = findPackageLocation(pkgName, allPackages)
    if location:
        listCat, pkgCat = location
        print(f"{FORMAT_ERROR} Package '{pkgName}' is already registered in the {listCat} list ({pkgCat}).{FORMAT_RESET}")
        return

    print(f"Package found in: {FORMAT_TITLE}{repoType.upper()}{FORMAT_RESET}")
    listType: str = ""
    while listType not in ["base", "extra"]:
        listType = input("Which list do you want to add it to? (base/extra): ").strip().lower()

    allPackages[listType][repoType].append(pkgName)
    savePackages(listType, allPackages[listType])
    print(f"{FORMAT_SUCCESS} Package '{pkgName}' successfully added to the '{listType}' list.{FORMAT_RESET}")


def removePackage(pkgName: str) -> None:
    allPackages: Dict[str, Dict[str, List[str]]] = loadAllPackages()
    location: Optional[tuple[str,str]] = findPackageLocation(pkgName, allPackages)

    if location:
        listCat, pkgCat = location
        allPackages[listCat][pkgCat].remove(pkgName)
        savePackages(listCat, allPackages[listCat])
        print(f"{FORMAT_SUCCESS} Package '{pkgName}' was removed from the '{listCat}' list ({pkgCat}).{FORMAT_RESET}")
    else:
        print(f"{FORMAT_ERROR} Package '{pkgName}' was not found in any of your lists.{FORMAT_RESET}")


def searchPackage(pkgName: str) -> None:
    allPackages: Dict[str, Dict[str, List[str]]] = loadAllPackages()
    location: Optional[tuple[str,str]] = findPackageLocation(pkgName, allPackages)

    if location:
        listCat, pkgCat = location
        print(f"{FORMAT_SUCCESS} Package '{pkgName}' found in list: {FORMAT_RESET}{listCat.upper()} ({pkgCat.upper()})")
    else:
        print(f"{FORMAT_ERROR} Package '{pkgName}' was not found in any of your lists.{FORMAT_RESET}")


def listPackages(filterArg: Optional[str]) -> None:
    allPackages: Dict[str, Dict[str, List[str]]] = loadAllPackages()
    foundAny: bool = False

    for listCategory in ["base", "extra"]:
        if filterArg in [None, "pacman", "aur"] or filterArg == listCategory:
            for packagescategory in ["pacman", "aur"]:
                if filterArg in [None, "base", "extra"] or filterArg == packagescategory:
                    pkgs = allPackages[listCategory][packagescategory]
                    if pkgs:
                        print(f"\n{FORMAT_TITLE}{listCategory.upper()} ({packagescategory.upper()}):{FORMAT_RESET}")
                        rawText = "\n".join(sorted(pkgs))
                        try:
                            subprocess.run(['column'], input=rawText, text=True)
                        except FileNotFoundError:
                            print(rawText)
                        foundAny = True
    if not foundAny:
        print("No packages to display with that filter.")


def main():
    if len(sys.argv) < 2:
        printHelp()
        return

    action: str = sys.argv[1]

    if action == "add":
        if len(sys.argv) < 3:
            print(f"{FORMAT_ERROR} You must specify a package: packages add <package>{FORMAT_RESET}")
            return
        addPackage(sys.argv[2])

    elif action == "remove":
        if len(sys.argv) < 3:
            print(f"{FORMAT_ERROR} You must specify a package: packages remove <package>{FORMAT_RESET}")
            return
        removePackage(sys.argv[2])

    elif action == "search":
        if len(sys.argv) < 3:
            print(f"{FORMAT_ERROR} You must specify a package: packages search <package>{FORMAT_RESET}")
            return
        searchPackage(sys.argv[2])

    elif action == "list":
        filterArg = sys.argv[2].lower() if len(sys.argv) > 2 else None
        if filterArg and filterArg not in ["base", "extra", "pacman", "aur"]:
            print(f"{FORMAT_ERROR} Invalid filter. Use: base, extra, pacman or aur.{FORMAT_RESET}")
            return
        listPackages(filterArg)

    else:
        print(f"{FORMAT_ERROR} Invalid action.{FORMAT_RESET}")
        printHelp()


if __name__ == "__main__":
    main()
